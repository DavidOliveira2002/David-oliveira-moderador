package com.moderador.service;

import com.moderador.model.Acao;
import com.moderador.model.Moderador;
import com.moderador.repository.AcaoRepository;
import com.moderador.repository.ModeradorRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.time.LocalDateTime;
import java.util.HashMap;
import java.util.List;
import java.util.Map;

@Service
public class ScoreService {

    @Autowired
    private ModeradorRepository moderadorRepository;

    @Autowired
    private AcaoRepository acaoRepository;

    private final Map<String, Integer> pontuacaoPorAcao = new HashMap<>();

    public ScoreService() {
        // Tabela de pontuação
        pontuacaoPorAcao.put("BANIR_USUARIO", 20);
        pontuacaoPorAcao.put("REMOVER_POST", 15);
        pontuacaoPorAcao.put("EDITAR_POST", 10);
        pontuacaoPorAcao.put("ADVERTENCIA", 12);
        pontuacaoPorAcao.put("APROVAR_CONTEUDO", 8);
        pontuacaoPorAcao.put("MODERAR_CHAT", 5);
        pontuacaoPorAcao.put("RESPONDER_DENUNCIA", 10);
        pontuacaoPorAcao.put("BLOQUEAR_COMENTARIO", 7);
        pontuacaoPorAcao.put("VERIFICAR_DENUNCIA", 6);
        pontuacaoPorAcao.put("MEDIAR_CONFLITO", 15);
    }

    @Transactional
    public Acao registrarAcao(Long moderadorId, String tipo, String descricao, Long alvoId, String alvoNome) {
        Moderador moderador = moderadorRepository.findById(moderadorId)
                .orElseThrow(() -> new RuntimeException("Moderador não encontrado"));

        Integer pontuacao = pontuacaoPorAcao.getOrDefault(tipo.toUpperCase(), 5);

        Acao acao = new Acao();
        acao.setModerador(moderador);
        acao.setTipo(tipo.toUpperCase());
        acao.setDescricao(descricao);
        acao.setPontuacao(pontuacao);
        acao.setAlvoId(alvoId);
        acao.setAlvoNome(alvoNome);
        acao.setDataAcao(LocalDateTime.now());

        // Atualizar score do moderador
        moderador.setScoreTotal(moderador.getScoreTotal() + pontuacao);
        moderador.setTotalAcoes(moderador.getTotalAcoes() + 1);
        moderador.setUltimaAtividade(LocalDateTime.now());
        
        // Atualizar nível baseado no score
        atualizarNivel(moderador);
        
        moderadorRepository.save(moderador);
        
        return acaoRepository.save(acao);
    }

    private void atualizarNivel(Moderador moderador) {
        int score = moderador.getScoreTotal();
        
        if (score >= 5000) {
            moderador.setNivel("LENDARIO");
        } else if (score >= 2000) {
            moderador.setNivel("DIAMANTE");
        } else if (score >= 1000) {
            moderador.setNivel("OURO");
        } else if (score >= 500) {
            moderador.setNivel("PRATA");
        } else {
            moderador.setNivel("BRONZE");
        }
    }

    public List<Acao> getHistorico(Long moderadorId) {
        return acaoRepository.findByModeradorIdOrderByDataAcaoDesc(moderadorId);
    }

    public Map<String, Integer> getPontuacaoPorAcao() {
        return pontuacaoPorAcao;
    }
}
